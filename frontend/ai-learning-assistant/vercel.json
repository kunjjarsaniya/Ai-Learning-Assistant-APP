{
    "rewrites": [
        {
            "source": "/((?!.*\\.).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/favicon.png",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
            ]
        },
        {
            "source": "/logo-512x512.png",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
            ]
        },
        {
            "source": "/og-image.png",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
            ]
        },
        {
            "source": "/(.*).png",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
            ]
        },
        {
            "source": "/(.*).ico",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" }
            ]
        },
        {
            "source": "/index.html",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
            ]
        }
    ]
}